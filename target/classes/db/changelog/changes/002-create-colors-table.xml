<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="002" author="dmaicas">
        <comment>Tabla de colores disponibles en One Piece TCG</comment>
        
        <createTable tableName="colors">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            
            <column name="name" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
        
        <!-- Insertar los 6 colores oficiales de One Piece TCG -->
        <insert tableName="colors">
            <column name="name" value="Red"/>
        </insert>
        <insert tableName="colors">
            <column name="name" value="Green"/>
        </insert>
        <insert tableName="colors">
            <column name="name" value="Blue"/>
        </insert>
        <insert tableName="colors">
            <column name="name" value="Yellow"/>
        </insert>
        <insert tableName="colors">
            <column name="name" value="Purple"/>
        </insert>
        <insert tableName="colors">
            <column name="name" value="Black"/>
        </insert>
        
    </changeSet>

</databaseChangeLog>
